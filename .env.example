# Required (production)
DATABASE_URL=mysql://user:password@host:3306/dbname
API_KEY=replace-me-openssl-rand-hex-32
NODE_ENV=production

# Optional
# SINGLE_USER_ID=  # if unset, auto-generated on first boot and printed to logs
# PORT=3000        # Railway sets this; default 3000

# Local dev (SQLite)
# DATABASE_URL=local.db
# DB_DIALECT=sqlite
